# .clang-format
BasedOnStyle: Google  # 以 Google 风格为基础（也可选 LLVM、Chromium 等）
IndentWidth: 4
UseTab: Never

# 大括号在行尾不换行（即 Allman → K&R / Stroustrup 风格）
BreakBeforeBraces: Attach  # 函数、类、控制结构的大括号不换行，紧跟在语句后

# 不允许单独函数体
AllowShortFunctionsOnASingleLine: false

# 命名空间尾部自动加注释（如 }  // namespace myns）
NamespaceIndentation: None  # 命名空间内部不额外缩进（可选）
CommentPragmas: '^ IWYU pragma:'  # 保留 IWYU 等注释（可选）

# 启用命名空间结束注释
NamespaceMacros: []  # 如果你有自定义命名空间宏，可在此列出
FixNamespaceComments: true  # 自动在命名空间结束处添加 // namespace xxx 注释

# 设置代码的列限制，即一行代码建议不超过 120 个字符，超过后会触发自动换行等格式化行为
ColumnLimit: 120

# 左括号（如函数、类的左括号）之后的代码（如参数、成员）会对齐排列
AlignAfterOpenBracket: Align

# 不允许短代码块（如只有一行的 if、for 等代码块）写在同一行
AllowShortBlocksOnASingleLine: false

# 完全不允许短 if 语句（如只有一行执行代码的 if）写在同一行
AllowShortIfStatementsOnASingleLine: Never

# 按照一定规则（如字母序）对 #include 进行排序，
SortIncludes: true